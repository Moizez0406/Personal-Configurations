        { "key": "в”‚ у°Ќ› cpu     в”‚", "type": "cpu", "showPeCoreCount": true, "keyColor": "blue"},
        { "key": "в”‚ у°‰‰ disk    в”‚", "type": "disk", "folders": "/", "keyColor": "blue"},
        { "key": "в”‚ ої… memory  в”‚", "type": "memory", "keyColor": "blue"},
        { "key": "в”њв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”¤", "type": "custom", "keyColor": "blue" },
        { "key": "в”‚ PC        в”‚", "type": "host", "format": "{5} {1} ({2})", "keyColor": "blue" },
        { "key": "в”‚ в”њ у°ў® gpu   в”‚", "type": "gpu", "format": "{1} {2} @ {12}", "keyColor": "blue" },
        { "key": "в”‚ в”њ у°“Ў swap  в”‚", "type": "swap", "keyColor": "blue" },
        { "key": "в”‚ в”њ п„€ disp  в”‚", "type": "monitor", "format": "{1} px @ {2} Hz - {3} mm ({4} inches, {5} pp)", "keyColor": "blue" },
        { "key": "в”‚ в”” пѓ§ dtime в”‚", "type": "command", "text": "birth_install=$(stat -c %W /); current=$(date +%s); time_progression=$((current - birth_install)); days_difference=$((time_progression / 86400)); echo $days_difference days", "keyColor": "blue" },
        { "key": "в•°в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв•Ї", "type": "custom", "keyColor": "blue" },
