        { "key": "в”‚ у°‡… hname   в”‚", "type": "title", "format": "{host-name}", "keyColor": "blue"},
        { "key": "в”‚ у°…ђ uptime  в”‚", "type": "uptime", "keyColor": "blue"},
        { "key": "в”‚ п…ј distro  в”‚", "type": "os", "keyColor": "blue"},
        { "key": "в”‚ пЂ“ kernel  в”‚", "type": "kernel", "keyColor": "blue"},
